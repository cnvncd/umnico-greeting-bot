# Umnico логин и пароль для OAuth авторизации
UMNICO_LOGIN=your_email@example.com
UMNICO_PASSWORD=your_password

# Файл для отправки (путь относительно app.py)
GREETING_FILE=NURKA Salem.ogg

# Тип файла: audio, video, photo, doc
FILE_TYPE=audio

# ID интеграции (найти в Umnico → Интеграции)
TARGET_SA_ID=110418

# Интервал опроса API в секундах
POLL_INTERVAL=10

# Файл для логов
LOG_FILE=bot.log
