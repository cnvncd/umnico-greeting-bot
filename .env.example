# Umnico логин и пароль для OAuth авторизации
UMNICO_LOGIN=your_email@example.com
UMNICO_PASSWORD=your_password

# Тип файла: audio, video, photo, doc
FILE_TYPE=audio

# Интервал опроса API в секундах (для app.py)
POLL_INTERVAL=10

# Порт для webhook сервера (для app_webhook.py)
WEBHOOK_PORT=5000

# Файл для логов
LOG_FILE=bot.log

# Конфигурация интеграций (формат: ID1:файл1,ID2:файл2)
# Пример: 108954:Салем_1.ogg,110418:NURKA Salem.ogg
INTEGRATIONS=108954:Салем_1.ogg,110418:NURKA Salem.ogg
